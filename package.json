{
  "name": "wechat-ilink-client",
  "version": "0.1.0",
  "description": "Standalone WeChat iLink bot protocol client",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.service.json",
    "clean": "rm -rf dist",
    "echo-bot": "tsx examples/echo-bot.ts",
    "api-server": "tsx service/index.ts",
    "check:examples": "tsc -p examples/tsconfig.json",
    "test:service": "node --import tsx --test test/api-server.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0"
  },
  "optionalDependencies": {
    "qrcode-terminal": "^0.12.0"
  },
  "dependencies": {
    "@fastify/multipart": "^10.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "fastify": "^5.8.4"
  }
}
